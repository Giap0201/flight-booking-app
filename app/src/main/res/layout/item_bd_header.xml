<?xml version="1.0" encoding="utf-8"?>
<!-- Item: Thông tin header booking (PNR, status, contact) -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Dòng 1: Logo + Order ID -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✈ Bookingspace"
                android:textColor="#5E35B1"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPnrCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="PNR: TBW7FWZ" />
        </RelativeLayout>

        <!-- Dòng 2: Status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_badge_paid"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Đã thanh toán" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#EEEEEE" />

        <!-- Dòng 3: Thông tin liên hệ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin liên hệ"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawablePadding="8dp"
            android:textColor="#424242"
            android:textSize="13sp"
            tools:text="👤 Nguyễn Văn A" />

        <TextView
            android:id="@+id/tvContactEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="8dp"
            android:textColor="#424242"
            android:textSize="13sp"
            tools:text="✉ email@example.com" />

        <TextView
            android:id="@+id/tvContactPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="8dp"
            android:textColor="#424242"
            android:textSize="13sp"
            tools:text="📞 0987654321" />

        <!-- Divider trước nút thanh toán -->
        <View
            android:id="@+id/dividerPayment"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#EEEEEE"
            android:visibility="gone" />

        <!-- Nút Thanh toán — chỉ hiển thị khi status = PENDING / AWAITING_PAYMENT -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💳  Thanh toán ngay"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorPrimary"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textEnd"
            app:iconTint="@android:color/white" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
