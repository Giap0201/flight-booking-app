<?xml version="1.0" encoding="utf-8"?>
<!-- Item: Một vé chi tiết (con của hành khách) -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginStart="32dp"
    android:layout_marginTop="6dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Dòng 1: Ticket number + Status -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvTicketNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="🎫 VN-TKT-001" />

            <TextView
                android:id="@+id/tvTicketStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_paid"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="RESERVED" />
        </RelativeLayout>

        <!-- Dòng 2: Chuyến bay + Hạng -->
        <TextView
            android:id="@+id/tvFlightAndClass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#757575"
            android:textSize="13sp"
            tools:text="✈ VN123 • First class" />

        <!-- Dòng 3: Sân bay -->
        <TextView
            android:id="@+id/tvRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#424242"
            android:textSize="13sp"
            tools:text="HAN → SGN" />

        <!-- Dòng 4: Giờ bay + Ghế ngồi -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvTicketTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#757575"
                android:textSize="12sp"
                tools:text="16:55 → 20:30" />

            <TextView
                android:id="@+id/tvSeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="#424242"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Ghế: 5A" />
        </RelativeLayout>

        <!-- Dòng 5: Giá vé -->
        <TextView
            android:id="@+id/tvTicketAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#5E35B1"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="2.500.000 ₫" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
