<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp"> <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="180dp"

        app:layout_constraintTop_toTopOf="parent" />

<!--        android:background="@drawable/bg_profile_header"-->

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Ngọc Yến"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/tvEditSubtitle"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toTopOf="@id/imgAvatar" />

        <TextView
            android:id="@+id/tvEditSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit personal information >"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/imgAvatar"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenu1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerBg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/menuEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="Change Profile Info"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <TextView
                    android:id="@+id/menuChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/ic_secure"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="Change Password"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <TextView
                    android:id="@+id/menuTransaction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="Transaction History"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenu2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardMenu1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/menuAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/ic_menu_info_details"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="About Blue Line Travel"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <TextView
                    android:id="@+id/menuRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/btn_star"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="Rate this App"
                    android:textColor="#333333"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <TextView
                    android:id="@+id/menuTerms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@android:drawable/ic_menu_agenda"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:text="Terms &amp; Conditions"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>